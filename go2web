#!/usr/bin/env node
'use strict';

const net = require('net');
const tls = require('tls');
const fs = require('fs');
const path = require('path');
const crypto = require('crypto');
const readline = require('readline');
const { URL } = require('url');
const cheerio = require('cheerio');

const args = process.argv.slice(2);

// ---------------------------------------------------------------------------
// Raw HTTP over TCP
// ---------------------------------------------------------------------------

const DEFAULT_TIMEOUT = 10000;
const MAX_REDIRECTS = 10;

function buildRequest(method, path, host, extraHeaders = {}) {
  const headers = {
    Host: host,
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36',
    Connection: 'close',
    Accept: 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
    'Accept-Language': 'en-US,en;q=0.5',
    'Accept-Encoding': 'identity',
    ...extraHeaders,
  };
  const headerLines = Object.entries(headers)
    .map(([k, v]) => `${k}: ${v}`)
    .join('\r\n');
  return `${method} ${path} HTTP/1.1\r\n${headerLines}\r\n\r\n`;
}

const CRLF2 = Buffer.from('\r\n\r\n');
const CRLF  = Buffer.from('\r\n');

function parseResponse(rawBuf) {
  // Find end of headers
  let headerEnd = -1;
  let sepLen = 4;
  for (let i = 0; i < rawBuf.length - 3; i++) {
    if (rawBuf[i] === 13 && rawBuf[i+1] === 10 && rawBuf[i+2] === 13 && rawBuf[i+3] === 10) {
      headerEnd = i; break;
    }
  }
  if (headerEnd === -1) { headerEnd = rawBuf.indexOf('\n\n'); sepLen = 2; }

  const headerSection = rawBuf.subarray(0, headerEnd).toString('utf8');
  const bodyBuf = rawBuf.subarray(headerEnd + sepLen);

  const lines = headerSection.split(/\r\n|\n/);
  const statusCode = parseInt(lines[0].split(' ')[1], 10);

  const headers = {};
  for (let i = 1; i < lines.length; i++) {
    const colon = lines[i].indexOf(':');
    if (colon !== -1) {
      headers[lines[i].substring(0, colon).trim().toLowerCase()] =
        lines[i].substring(colon + 1).trim();
    }
  }

  return { statusCode, headers, bodyBuf };
}

function decodeChunked(buf) {
  const parts = [];
  let pos = 0;
  while (pos < buf.length) {
    const crlf = buf.indexOf(CRLF, pos);
    if (crlf === -1) break;
    const sizeLine = buf.subarray(pos, crlf).toString('ascii').split(';')[0].trim();
    const size = parseInt(sizeLine, 16);
    if (!size) break;
    parts.push(buf.subarray(crlf + 2, crlf + 2 + size));
    pos = crlf + 2 + size + 2;
  }
  return Buffer.concat(parts);
}

function rawRequest(urlStr, extraHeaders = {}) {
  return new Promise((resolve, reject) => {
    const parsed = new URL(urlStr);
    const scheme = parsed.protocol.slice(0, -1); // remove trailing ':'
    const host = parsed.hostname;
    const port = parsed.port
      ? parseInt(parsed.port, 10)
      : scheme === 'https' ? 443 : 80;
    const path = (parsed.pathname || '/') + (parsed.search || '');
    const hostHeader = parsed.port ? `${host}:${parsed.port}` : host;

    const request = buildRequest('GET', path, hostHeader, extraHeaders);

    const chunks = [];
    const connectOpts = { host, port };

    const onConnect = (socket) => {
      socket.setTimeout(DEFAULT_TIMEOUT);
      socket.on('timeout', () => { socket.destroy(new Error('Request timed out')); });
      socket.on('error', reject);
      socket.on('data', chunk => chunks.push(chunk));
      socket.on('end', () => {
        const rawBuf = Buffer.concat(chunks);
        let { statusCode, headers, bodyBuf } = parseResponse(rawBuf);

        if ((headers['transfer-encoding'] || '').toLowerCase() === 'chunked') {
          bodyBuf = decodeChunked(bodyBuf);
        }

        const charset = (headers['content-type'] || '').match(/charset=([^\s;]+)/i);
        const enc = charset ? charset[1].toLowerCase().replace('-', '') : 'utf8';
        const body = bodyBuf.toString(enc === 'utf8' ? 'utf8' : 'latin1');

        resolve({ statusCode, headers, body });
      });
      socket.write(request);
    };

    if (scheme === 'https') {
      const socket = tls.connect({ ...connectOpts, servername: host, rejectUnauthorized: false }, () => onConnect(socket));
      socket.on('error', reject);
    } else {
      const socket = net.createConnection(connectOpts, () => onConnect(socket));
      socket.on('error', reject);
    }
  });
}

// ---------------------------------------------------------------------------
// File-based HTTP cache
// ---------------------------------------------------------------------------

const CACHE_DIR = path.join(require('os').homedir(), '.go2web-cache');
const DEFAULT_TTL_MS = 60 * 60 * 1000; // 1 hour

function ensureCacheDir() {
  if (!fs.existsSync(CACHE_DIR)) fs.mkdirSync(CACHE_DIR, { recursive: true });
}

function cacheKey(url) {
  return crypto.createHash('sha1').update(url).digest('hex');
}

function cacheGet(url) {
  ensureCacheDir();
  const file = path.join(CACHE_DIR, cacheKey(url) + '.json');
  if (!fs.existsSync(file)) return null;
  try {
    const entry = JSON.parse(fs.readFileSync(file, 'utf8'));
    if (Date.now() < entry.expiresAt) return entry.response;
    fs.unlinkSync(file); // expired
  } catch (_) {}
  return null;
}

function cacheSet(url, response) {
  ensureCacheDir();
  const { headers } = response;

  let ttlMs = DEFAULT_TTL_MS;
  const cc = headers['cache-control'] || '';
  const maxAgeMatch = cc.match(/max-age=(\d+)/i);
  if (maxAgeMatch) {
    ttlMs = parseInt(maxAgeMatch[1], 10) * 1000;
  } else if (headers['expires']) {
    const exp = Date.parse(headers['expires']);
    if (!isNaN(exp)) ttlMs = Math.max(0, exp - Date.now());
  }

  if (ttlMs <= 0) return; // don't cache no-store/no-cache responses

  const entry = { expiresAt: Date.now() + ttlMs, response };
  const file = path.join(CACHE_DIR, cacheKey(url) + '.json');
  fs.writeFileSync(file, JSON.stringify(entry), 'utf8');
}

// ---------------------------------------------------------------------------
// HTML → plain text
// ---------------------------------------------------------------------------

function htmlToText(html) {
  const $ = cheerio.load(html);

  // Remove non-content elements
  $('script, style, noscript, head').remove();

  // Replace block-level elements with newlines
  $('br').replaceWith('\n');
  $('p, div, section, article, header, footer, li, tr, h1, h2, h3, h4, h5, h6').each((_, el) => {
    $(el).prepend('\n');
    $(el).append('\n');
  });
  $('h1, h2, h3').each((_, el) => {
    const text = $(el).text().trim();
    const level = el.name;
    const underline = level === 'h1' ? '=' : level === 'h2' ? '-' : '~';
    $(el).replaceWith(`\n${text}\n${underline.repeat(text.length)}\n`);
  });

  // Show link URLs inline
  $('a').each((_, el) => {
    const href = $(el).attr('href');
    const text = $(el).text().trim();
    if (href && !href.startsWith('#') && !href.startsWith('javascript')) {
      $(el).replaceWith(href.startsWith('http') ? `${text} [${href}]` : text);
    }
  });

  let text = $.text();
  // Collapse excessive blank lines
  text = text.replace(/\n{3,}/g, '\n\n').trim();
  return text;
}

// ---------------------------------------------------------------------------
// CLI commands
// ---------------------------------------------------------------------------

function showHelp() {
  console.log(`go2web - HTTP client over raw TCP sockets

Usage:
  go2web -u <URL>          Make an HTTP request to the URL and print response
  go2web -s <search-term>  Search the web and print top 10 results
  go2web -h                Show this help message

Examples:
  go2web -u https://example.com
  go2web -s python tcp sockets
  go2web -s "hello world"
`);
}

function parseArgs(argv) {
  const result = {};
  for (let i = 0; i < argv.length; i++) {
    if (argv[i] === '-h') result.help = true;
    else if (argv[i] === '-u' && argv[i + 1]) result.url = argv[++i];
    else if (argv[i] === '-s') {
      result.search = argv.slice(i + 1).join(' ');
      break;
    }
  }
  return result;
}

async function fetchWithRedirects(url, extraHeaders = {}) {
  let currentUrl = url;
  for (let i = 0; i < MAX_REDIRECTS; i++) {
    // Check cache before making a network request
    const cached = cacheGet(currentUrl);
    if (cached) {
      process.stderr.write(`  [CACHE HIT] ${currentUrl}\n`);
      return cached;
    }

    const result = await rawRequest(currentUrl, extraHeaders);
    const { statusCode, headers } = result;

    if ([301, 302, 303, 307, 308].includes(statusCode) && headers['location']) {
      const location = headers['location'];
      currentUrl = location.startsWith('http')
        ? location
        : new URL(location, currentUrl).toString();
      process.stderr.write(`  → redirect to ${currentUrl}\n`);
    } else {
      // Cache successful responses
      if (statusCode === 200) cacheSet(currentUrl, result);
      return result;
    }
  }
  throw new Error(`Too many redirects (max ${MAX_REDIRECTS})`);
}

function formatBody(headers, body) {
  const contentType = headers['content-type'] || '';
  if (contentType.includes('application/json')) {
    try {
      return JSON.stringify(JSON.parse(body), null, 2);
    } catch (_) {
      return body;
    }
  }
  if (contentType.includes('text/html')) {
    return htmlToText(body);
  }
  return body;
}

async function cmdUrl(url) {
  // Advertise both JSON and HTML; prefer JSON if available
  const { statusCode, headers, body } = await fetchWithRedirects(url, {
    Accept: 'application/json,text/html;q=0.9,*/*;q=0.8',
  });
  const contentType = headers['content-type'] || '';
  console.log(`[HTTP ${statusCode}] [${contentType}]\n`);
  console.log(formatBody(headers, body));
}

async function cmdSearch(term) {
  const query = encodeURIComponent(term);
  const searchUrl = `https://lite.duckduckgo.com/lite/?q=${query}`;

  const { statusCode, headers, body } = await fetchWithRedirects(searchUrl, {
    Accept: 'text/html',
  });

  if (statusCode !== 200) {
    console.error(`Search failed with HTTP ${statusCode}`);
    process.exit(1);
  }

  const $ = cheerio.load(body);
  const results = [];

  $('a.result-link').each((_, el) => {
    if (results.length >= 10) return;
    const title = $(el).text().trim();
    const rawHref = $(el).attr('href') || '';

    // Extract real URL from DDG redirect wrapper
    let url = rawHref;
    try {
      const u = new URL('https://duckduckgo.com' + rawHref);
      const uddg = u.searchParams.get('uddg');
      if (uddg) url = decodeURIComponent(uddg);
    } catch (_) {
      if (rawHref.startsWith('//')) url = 'https:' + rawHref;
    }

    // Snippet is in the next table row
    const snippet = $(el).closest('tr').next('tr').find('.result-snippet').text().trim();

    if (title && url.startsWith('http')) results.push({ title, url, snippet });
  });

  if (results.length === 0) {
    console.log('No results found.');
    return;
  }

  results.forEach((r, i) => {
    console.log(`${i + 1}. ${r.title}`);
    console.log(`   ${r.url}`);
    if (r.snippet) console.log(`   ${r.snippet}`);
    console.log();
  });

  await promptOpenResult(results);
}

function promptOpenResult(results) {
  return new Promise((resolve) => {
    const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
    rl.question('Open result (1-10) or press Enter to quit: ', async (answer) => {
      rl.close();
      const n = parseInt(answer, 10);
      if (!isNaN(n) && n >= 1 && n <= results.length) {
        const chosen = results[n - 1];
        console.log(`\nFetching: ${chosen.url}\n`);
        try {
          const { statusCode, headers, body } = await fetchWithRedirects(chosen.url, {
            Accept: 'application/json,text/html;q=0.9,*/*;q=0.8',
          });
          const contentType = headers['content-type'] || '';
          console.log(`[HTTP ${statusCode}] [${contentType}]\n`);
          console.log(formatBody(headers, body));
        } catch (e) {
          console.error(`Error: ${e.message}`);
        }
      }
      resolve();
    });
  });
}

async function main() {
  const opts = parseArgs(args);

  if (opts.help || args.length === 0) {
    showHelp();
  } else if (opts.url) {
    await cmdUrl(opts.url);
  } else if (opts.search) {
    await cmdSearch(opts.search);
  } else {
    showHelp();
  }
}

main().catch(err => {
  console.error('Error:', err.message);
  process.exit(1);
});
